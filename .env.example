# ---------------------------------------------------------------------------
# Graphon (memory system under test)
# ---------------------------------------------------------------------------
# Get an API key from https://app.graphon.ai/ -> Settings -> API Keys
GRAPHON_API_KEY=your-graphon-api-key-here
# Optional. Defaults to the SDK default (https://api.graphon.ai).
# GRAPHON_BASE_URL=https://api.graphon.ai

# ---------------------------------------------------------------------------
# OpenAI (shared reader + key-fact judge; one model for every LLM role)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
# Optional overrides (defaults come from config.yaml)
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
